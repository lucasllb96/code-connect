{
  "name": "code-connect-workspace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "pnpm --filter api exec prisma migrate reset",
